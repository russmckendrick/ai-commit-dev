{
	"compatibility_date": "2026-04-12",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "ai-commit-dev",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"routes": [
		{ "pattern": "ai-commit.dev", "custom_domain": true },
		{ "pattern": "www.ai-commit.dev", "custom_domain": true }
	],
	"observability": {
		"enabled": true
	}
}