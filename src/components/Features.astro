---
import FeatureCard from './FeatureCard.astro';

const features = [
  {
    icon: 'commit',
    title: 'Smart Commits',
    description: 'Generate conventional commit messages from your staged diff. Detects scopes from file paths and ticket references from branch names.',
    command: 'aic',
  },
  {
    icon: 'review',
    title: 'Diff Review',
    description: 'AI-powered code review with findings grouped by severity — critical, warning, and suggestion — before you commit.',
    command: 'aic review',
  },
  {
    icon: 'pr',
    title: 'PR Drafts',
    description: 'Generate a pull request title and Markdown description from your branch commits and diff against a base branch.',
    command: 'aic pr',
  },
  {
    icon: 'log',
    title: 'Log Rewrite',
    description: 'Clean up the last N commit messages on your branch using AI. Shows a before/after comparison before rewriting.',
    command: 'aic log',
  },
  {
    icon: 'map',
    title: 'Visualizations',
    description: 'Generate SVG treemaps, commit timelines, file heatmaps, and activity graphs — all themed to match your editor.',
    command: 'aic map tree',
  },
  {
    icon: 'split',
    title: 'Split Commits',
    description: 'Turn one staged change set into multiple file-group commits when your work spans separate concerns. AI suggests the groups.',
    command: 'aic',
  },
];
---

<section id="features" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="scroll-reveal mx-auto max-w-2xl text-center">
      <p class="text-sm font-medium uppercase tracking-[0.14em] text-accent">Features</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight text-text">
        Everything you need in your terminal
      </h2>
      <p class="mt-4 text-base text-text-secondary leading-relaxed">
        From commit messages to code review to PR drafts — <code>aic</code> keeps you in flow.
      </p>
    </div>

    <div class="scroll-reveal-stagger mt-14 grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <FeatureCard
          icon={f.icon}
          title={f.title}
          description={f.description}
          command={f.command}
        />
      ))}
    </div>
  </div>
</section>
