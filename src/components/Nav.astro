---
import ThemeSwitcher from './ThemeSwitcher.astro';
import GithubIcon from './icons/GithubIcon';
---

<nav class="fixed inset-x-0 top-0 z-50 border-b border-border/60 bg-bg/70 backdrop-blur-xl supports-[backdrop-filter]:bg-bg/50">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-text hover:text-accent transition-colors">
      <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-accent/10 ring-1 ring-accent/30">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-accent">
          <circle cx="12" cy="12" r="3"/>
          <line x1="3" y1="12" x2="9" y2="12"/>
          <line x1="15" y1="12" x2="21" y2="12"/>
        </svg>
      </span>
      <span class="font-semibold tracking-tight text-[15px]">aic</span>
    </a>

    <!-- Center links -->
    <div class="hidden md:flex items-center gap-1">
      <a href="/#features" class="px-3 py-2 text-sm text-text-secondary hover:text-text hover:bg-surface/60 rounded-lg transition-colors">Features</a>
      <a href="/#visualizations" class="px-3 py-2 text-sm text-text-secondary hover:text-text hover:bg-surface/60 rounded-lg transition-colors">Visualizations</a>
      <a href="/docs" class="px-3 py-2 text-sm text-text-secondary hover:text-text hover:bg-surface/60 rounded-lg transition-colors">Docs</a>
    </div>

    <!-- Right actions -->
    <div class="flex items-center gap-2">
      <div class="hidden md:block">
        <ThemeSwitcher variant="nav" />
      </div>

      <a href="https://github.com/russmckendrick/aicommit" target="_blank" rel="noopener noreferrer"
         class="hidden md:inline-flex items-center gap-2 px-3 py-2 text-sm text-text-secondary hover:text-text hover:bg-surface/60 rounded-lg transition-colors">
        <GithubIcon size={16} />
        <span>GitHub</span>
      </a>

      <a href="/docs/installation"
         class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-bg bg-accent hover:bg-accent-text rounded-lg transition-all shadow-sm">
        Get started
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>

      <button class="md:hidden p-2 text-text-secondary hover:text-text" aria-label="Toggle menu" aria-expanded="false" id="nav-hamburger">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile menu -->
<div id="mobile-menu" class="fixed inset-x-0 top-16 bottom-0 z-40 hidden flex-col gap-6 bg-bg px-6 py-8 md:hidden">
  <div class="flex flex-col gap-1">
    <a href="/#features" class="py-3 text-lg text-text hover:text-accent border-b border-border">Features</a>
    <a href="/#visualizations" class="py-3 text-lg text-text hover:text-accent border-b border-border">Visualizations</a>
    <a href="/docs" class="py-3 text-lg text-text hover:text-accent border-b border-border">Docs</a>
    <a href="https://github.com/russmckendrick/aicommit" target="_blank" rel="noopener noreferrer" class="py-3 text-lg text-text hover:text-accent border-b border-border">GitHub</a>
  </div>
  <div>
    <ThemeSwitcher variant="hero" />
  </div>
</div>

<script is:inline>
  (function() {
    var btn = document.getElementById('nav-hamburger');
    var menu = document.getElementById('mobile-menu');
    if (btn && menu) {
      btn.addEventListener('click', function() {
        var open = !menu.classList.contains('hidden');
        if (open) {
          menu.classList.add('hidden');
          menu.classList.remove('flex');
          btn.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        } else {
          menu.classList.remove('hidden');
          menu.classList.add('flex');
          btn.setAttribute('aria-expanded', 'true');
          document.body.style.overflow = 'hidden';
        }
      });
      menu.querySelectorAll('a').forEach(function(a) {
        a.addEventListener('click', function() {
          menu.classList.add('hidden');
          menu.classList.remove('flex');
          btn.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        });
      });
    }
  })();
</script>
