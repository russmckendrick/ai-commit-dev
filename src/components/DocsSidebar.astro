---
import { getCollection } from 'astro:content';
import Icon from './Icon.astro';
import { getReleases } from '../lib/releases';

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

const docs = await getCollection('docs');
const sorted = docs.sort((a, b) => a.data.order - b.data.order);

const releases = await getReleases();
const releasesExpanded = currentSlug === 'releases' || currentSlug?.startsWith('releases/');

const iconFor: Record<string, Parameters<typeof Icon>[0]['name']> = {
  installation: 'download',
  usage: 'terminal',
  configuration: 'sliders',
  providers: 'cpu',
  map: 'bar-chart',
  hooks: 'link',
  architecture: 'layers',
};
---

<aside class="docs-sidebar">
  <nav class="docs-sidebar__nav">
    <a href="/docs" class:list={['docs-sidebar__link', { active: !currentSlug }]}>
      <span class="docs-sidebar__mark" aria-hidden="true"></span>
      <Icon name="home" size={14} />
      <span>Overview</span>
    </a>
    {sorted.map((doc) => (
      <a
        href={`/docs/${doc.id}`}
        class:list={['docs-sidebar__link', { active: currentSlug === doc.id }]}
      >
        <span class="docs-sidebar__mark" aria-hidden="true"></span>
        <Icon name={iconFor[doc.id] ?? 'book-open'} size={14} />
        <span>{doc.data.title}</span>
      </a>
    ))}
    <a
      href="/releases"
      class:list={['docs-sidebar__link', { active: currentSlug === 'releases' }]}
    >
      <span class="docs-sidebar__mark" aria-hidden="true"></span>
      <Icon name="tag" size={14} />
      <span>Releases</span>
    </a>
    {releasesExpanded && releases.length > 0 && (
      <ul class="docs-sidebar__sublist">
        {releases.map((r) => (
          <li>
            <a
              href={`/releases/${r.tag}/`}
              class:list={['docs-sidebar__sublink', { active: currentSlug === `releases/${r.tag}` }]}
            >
              <span>{r.tag}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
    <div class="docs-sidebar__divider"></div>
    <a
      href="https://github.com/russmckendrick/aicommit"
      class="docs-sidebar__link docs-sidebar__link--external"
      target="_blank"
      rel="noopener noreferrer"
    >
      <span class="docs-sidebar__mark" aria-hidden="true"></span>
      <Icon name="github" size={14} />
      <span>GitHub</span>
      <Icon name="arrow-up-right" size={11} class="docs-sidebar__ext" />
    </a>
  </nav>
</aside>
