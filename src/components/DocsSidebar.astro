---
import { getCollection } from 'astro:content';

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

const docs = await getCollection('docs');
const sorted = docs.sort((a, b) => a.data.order - b.data.order);
---

<aside class="docs-sidebar">
  <nav class="docs-sidebar__nav">
    <a href="/docs" class:list={['docs-sidebar__link', { active: !currentSlug }]}>Overview</a>
    {sorted.map((doc) => (
      <a
        href={`/docs/${doc.id}`}
        class:list={['docs-sidebar__link', { active: currentSlug === doc.id }]}
      >
        {doc.data.title}
      </a>
    ))}
    <div class="docs-sidebar__divider"></div>
    <a href="https://github.com/russmckendrick/aicommit" class="docs-sidebar__link" target="_blank" rel="noopener noreferrer">
      GitHub ↗
    </a>
  </nav>
</aside>
