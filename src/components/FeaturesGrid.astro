---
const items = [
  { cmd: 'aic',         tag: 'commit',  desc: 'Generate a conventional commit from your staged diff. Scope-hinted, branch-aware, chunk-safe.', visual: 'commit' },
  { cmd: 'aic review',  tag: 'review',  desc: 'AI diff review grouped by severity — bugs, security, performance, correctness.', visual: 'review' },
  { cmd: 'aic pr',      tag: 'pr',      desc: "Draft a PR title and Markdown description from the branch's commits and cumulative diff.", visual: 'pr' },
  { cmd: 'aic log',     tag: 'log',     desc: 'Rewrite the last N commit messages on your branch before opening a PR.', visual: 'log' },
  { cmd: 'aic map',     tag: 'map',     desc: 'Treemap, timeline, heatmap, and activity grid — all SVG, 8 themes, no server.', visual: 'map' },
  { cmd: 'aic history', tag: 'history', desc: 'Everything aic generates is saved locally. Browse, filter, and reuse past messages.', visual: 'history' },
];
---

<section id="features">
  <div class="shell">
    <div class="section-kicker">Commands</div>
    <h2 class="section-title">One binary. Six flows.</h2>
    <p class="section-sub">Commit-message generation is the headline. Everything else — reviews, PRs, history rewrites, codebase visualizations — reuses the same config, providers, and prompt pipeline.</p>
    <div class="features">
      {items.map((it) => (
        <div class="feat">
          <div class="feat-head">
            <span class="dot"></span>
            <span>{it.tag}</span>
          </div>
          <div class="feat-cmd"><span class="dim">$ </span>{it.cmd}</div>
          <div class="feat-desc">{it.desc}</div>
          <div class="feat-visual">
            {it.visual === 'commit' && (
              <svg viewBox="0 0 300 120" width="100%" height="100%" preserveAspectRatio="xMidYMid meet">
                <g font-family="ui-monospace, monospace" font-size="10">
                  <text x="14" y="22" fill="var(--danger)">- let token = old_session();</text>
                  <text x="14" y="38" fill="var(--accent)">+ let token = rotate_on_role_change();</text>
                  <line x1="14" y1="54" x2="286" y2="54" stroke="var(--line-soft)" />
                  <text x="14" y="74" fill="var(--ink-dim)" font-size="9">$ aic</text>
                  <text x="14" y="92" fill="var(--accent)" font-weight="500">feat(auth): rotate tokens</text>
                  <text x="14" y="106" fill="var(--ink-dim)" font-size="9">on role change · PROJ-214</text>
                </g>
              </svg>
            )}
            {it.visual === 'review' && (
              <svg viewBox="0 0 300 120" width="100%" height="100%" preserveAspectRatio="xMidYMid meet">
                <g transform="translate(10, 12)">
                  <rect x="0" y="0" width="3" height="22" fill="var(--danger)" />
                  <text x="10" y="11" font-family="ui-monospace, monospace" font-size="9" fill="var(--danger)" font-weight="500">Critical</text>
                  <text x="56" y="11" font-family="ui-monospace, monospace" font-size="9" fill="var(--ink-dim)">L42</text>
                  <text x="10" y="22" font-family="ui-monospace, monospace" font-size="10" fill="var(--ink)">SQL string concat in query()</text>
                </g>
                <g transform="translate(10, 44)">
                  <rect x="0" y="0" width="3" height="22" fill="var(--warn)" />
                  <text x="10" y="11" font-family="ui-monospace, monospace" font-size="9" fill="var(--warn)" font-weight="500">Warning</text>
                  <text x="56" y="11" font-family="ui-monospace, monospace" font-size="9" fill="var(--ink-dim)">L87</text>
                  <text x="10" y="22" font-family="ui-monospace, monospace" font-size="10" fill="var(--ink)">unwrap() on network response</text>
                </g>
                <g transform="translate(10, 76)">
                  <rect x="0" y="0" width="3" height="22" fill="var(--blue)" />
                  <text x="10" y="11" font-family="ui-monospace, monospace" font-size="9" fill="var(--blue)" font-weight="500">Note</text>
                  <text x="56" y="11" font-family="ui-monospace, monospace" font-size="9" fill="var(--ink-dim)">L12</text>
                  <text x="10" y="22" font-family="ui-monospace, monospace" font-size="10" fill="var(--ink)">consider Result&lt;T, E&gt;</text>
                </g>
              </svg>
            )}
            {it.visual === 'pr' && (
              <svg viewBox="0 0 300 120" width="100%" height="100%" preserveAspectRatio="xMidYMid meet">
                <g font-family="ui-monospace, monospace">
                  <rect x="14" y="12" width="272" height="20" rx="3" fill="var(--bg-elev-2)" />
                  <text x="20" y="26" font-size="10" fill="var(--ink)" font-weight="500">Rotate session tokens on role change</text>
                  <text x="14" y="48" font-size="9" fill="var(--ink-dim)">## Summary</text>
                  <rect x="14" y="54" width="240" height="3" rx="1" fill="var(--ink-dim)" opacity="0.4" />
                  <rect x="14" y="60" width="210" height="3" rx="1" fill="var(--ink-dim)" opacity="0.4" />
                  <text x="14" y="78" font-size="9" fill="var(--ink-dim)">## Testing</text>
                  <rect x="14" y="84" width="180" height="3" rx="1" fill="var(--ink-dim)" opacity="0.4" />
                  <text x="14" y="104" font-size="9" fill="var(--accent)">+ 4 commits · 2 files</text>
                </g>
              </svg>
            )}
            {it.visual === 'log' && (
              <svg viewBox="0 0 300 120" width="100%" height="100%" preserveAspectRatio="xMidYMid meet">
                <g transform="translate(10, 14)" font-family="ui-monospace, monospace" font-size="9">
                  <text x="0" y="10" fill="var(--danger)" text-decoration="line-through">fix stuff</text>
                  <text x="0" y="24" fill="var(--accent)">fix(api): null-guard auth middleware</text>
                </g>
                <g transform="translate(10, 48)" font-family="ui-monospace, monospace" font-size="9">
                  <text x="0" y="10" fill="var(--danger)" text-decoration="line-through">more</text>
                  <text x="0" y="24" fill="var(--accent)">refactor(api): extract validator</text>
                </g>
                <g transform="translate(10, 82)" font-family="ui-monospace, monospace" font-size="9">
                  <text x="0" y="10" fill="var(--danger)" text-decoration="line-through">wip</text>
                  <text x="0" y="24" fill="var(--accent)">feat(api): add rate-limit headers</text>
                </g>
              </svg>
            )}
            {it.visual === 'map' && (
              <svg viewBox="0 0 300 120" width="100%" height="100%" preserveAspectRatio="xMidYMid meet">
                <rect x="0" y="0" width="300" height="120" fill="var(--bg-elev)" />
                {Array.from({ length: 20 }).map((_, c) => (
                  Array.from({ length: 7 }).map((_, r) => {
                    const seed = (c * 7 + r) * 9301 % 233280;
                    const v = seed / 233280;
                    const fill = v < 0.3 ? 'var(--line)' : 'var(--accent)';
                    const op = v < 0.3 ? 1 : 0.25 + v * 0.75;
                    return <rect x={20 + c * 13} y={20 + r * 11} width="9" height="9" rx="1.5" fill={fill} opacity={op} />;
                  })
                )).flat()}
              </svg>
            )}
            {it.visual === 'history' && (
              <svg viewBox="0 0 300 120" width="100%" height="100%" preserveAspectRatio="xMidYMid meet">
                <g transform="translate(10, 14)" font-family="ui-monospace, monospace">
                  <circle cx="6" cy="10" r="3" fill="var(--accent)" />
                  <text x="16" y="8" font-size="8" fill="var(--ink-dim)" letter-spacing="0.5">COMMIT</text>
                  <text x="16" y="21" font-size="10" fill="var(--ink)">feat(auth): rotate tokens</text>
                  <text x="270" y="14" font-size="9" fill="var(--ink-dim)" text-anchor="end">2m</text>
                </g>
                <g transform="translate(10, 46)" font-family="ui-monospace, monospace">
                  <circle cx="6" cy="10" r="3" fill="var(--warn)" />
                  <text x="16" y="8" font-size="8" fill="var(--ink-dim)" letter-spacing="0.5">REVIEW</text>
                  <text x="16" y="21" font-size="10" fill="var(--ink)">3 findings · src/api/login.ts</text>
                  <text x="270" y="14" font-size="9" fill="var(--ink-dim)" text-anchor="end">14m</text>
                </g>
                <g transform="translate(10, 78)" font-family="ui-monospace, monospace">
                  <circle cx="6" cy="10" r="3" fill="var(--blue)" />
                  <text x="16" y="8" font-size="8" fill="var(--ink-dim)" letter-spacing="0.5">PR</text>
                  <text x="16" y="21" font-size="10" fill="var(--ink)">Rotate session tokens on role…</text>
                  <text x="270" y="14" font-size="9" fill="var(--ink-dim)" text-anchor="end">1h</text>
                </g>
              </svg>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
