---
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'aic — AI-generated commits, reviews & PRs',
  description = 'aic is a Rust CLI that generates conventional commits, PR drafts, and diff reviews with the AI provider you already pay for.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="ai-commit.dev" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <script is:inline>
      (function() {
        var STORAGE_KEY = 'aic-theme';
        var DEFAULT_THEME = 'solarized-dark';
        var theme = DEFAULT_THEME;
        try { theme = localStorage.getItem(STORAGE_KEY) || DEFAULT_THEME; } catch(e) {}
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <script is:inline>
      (function() {
        var STORAGE_KEY = 'aic-theme';
        var DEFAULT_THEME = 'solarized-dark';

        function applyTheme(themeId) {
          document.documentElement.setAttribute('data-theme', themeId);
          try { localStorage.setItem(STORAGE_KEY, themeId); } catch(e) {}

          document.querySelectorAll('[data-viz-theme]').forEach(function(el) {
            el.style.display = el.getAttribute('data-viz-theme') === themeId ? '' : 'none';
          });

          document.querySelectorAll('[data-theme-btn]').forEach(function(btn) {
            var isActive = btn.getAttribute('data-theme-btn') === themeId;
            btn.classList.toggle('active', isActive);
            btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
          });

          var trigger = document.getElementById('theme-dd-trigger');
          if (trigger) {
            var swatch = trigger.querySelector('.swatch');
            var name = trigger.querySelector('.theme-dd-current');
            var data = trigger.dataset;
            if (data && data[themeId]) {
              try {
                var meta = JSON.parse(data[themeId]);
                if (swatch) { swatch.style.background = meta.bg; swatch.style.borderColor = meta.border; }
                if (name) name.textContent = meta.name;
              } catch(e) {}
            }
          }
        }

        var stored = DEFAULT_THEME;
        try { stored = localStorage.getItem(STORAGE_KEY) || DEFAULT_THEME; } catch(e) {}
        applyTheme(stored);

        window.__setTheme = applyTheme;
      })();
    </script>
  </body>
</html>
