---
import { themes } from '../data/themes';

const vizTypes = [
  { id: 'treemap', label: 'Treemap', prefix: 'treemap', description: 'File hierarchy sized by line count, colored by directory.' },
  { id: 'timeline', label: 'Timeline', prefix: 'timeline', description: 'Zigzag commit timeline with date circles and file-change dots.' },
  { id: 'heatmap', label: 'Heatmap', prefix: 'heatmap', description: 'Files ranked by modification frequency on a cold-to-hot scale.' },
  { id: 'activity', label: 'Activity', prefix: 'activity', description: 'GitHub-style contribution grid from commit timestamps.' },
];
---

<section id="visualizations" class="relative py-24 sm:py-32 overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="scroll-reveal mx-auto max-w-2xl text-center">
      <p class="text-sm font-medium uppercase tracking-[0.14em] text-accent">Visualize</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight text-text">
        See your codebase, not just read it.
      </h2>
      <p class="mt-4 text-base text-text-secondary leading-relaxed">
        Generate themed SVGs with <code>aic map</code>. They change with the theme above.
      </p>
    </div>

    <div class="mt-12 mx-auto max-w-4xl">
      <!-- Tabs -->
      <div class="flex items-center justify-center">
        <div class="inline-flex items-center gap-1 rounded-xl border border-border bg-surface/60 p-1 backdrop-blur">
          {vizTypes.map((viz, i) => (
            <button
              class:list={[
                'viz-tab px-4 py-1.5 text-sm font-medium rounded-lg transition-colors',
                i === 0 ? 'viz-tab-active' : 'text-text-secondary hover:text-text'
              ]}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              data-viz-tab={viz.id}
              onclick={`switchVizTab('${viz.id}')`}
            >
              {viz.label}
            </button>
          ))}
        </div>
      </div>

      <!-- Panels -->
      <div class="mt-6">
        {vizTypes.map((viz, i) => (
          <div
            class:list={[
              'viz-panel',
              i === 0 ? 'block' : 'hidden'
            ]}
            data-viz-panel={viz.id}
            role="tabpanel"
          >
            <p class="text-center text-sm text-text-secondary mb-5">{viz.description}</p>
            <div class="rounded-2xl border border-border bg-surface overflow-hidden shadow-2xl">
              {themes.map((theme) => (
                <img
                  src={`/maps/${viz.prefix}-${theme.id}.svg`}
                  alt={`${viz.label} in ${theme.name} theme`}
                  data-viz-theme={theme.id}
                  loading="lazy"
                  class="w-full h-auto block"
                />
              ))}
            </div>
            <div class="mt-4 flex justify-center">
              <code class="!bg-bg-deep/60 !text-accent text-sm font-medium px-3 py-1.5 rounded-md border border-border/60">
                $ aic map {viz.id === 'heatmap' ? 'heat' : viz.id === 'timeline' ? 'history' : viz.id}
              </code>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>


<script is:inline>
  function switchVizTab(id) {
    document.querySelectorAll('[data-viz-tab]').forEach(function(tab) {
      var isActive = tab.getAttribute('data-viz-tab') === id;
      tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
      if (isActive) {
        tab.classList.add('viz-tab-active');
        tab.classList.remove('text-text-secondary', 'hover:text-text');
      } else {
        tab.classList.remove('viz-tab-active');
        tab.classList.add('text-text-secondary', 'hover:text-text');
      }
    });
    document.querySelectorAll('[data-viz-panel]').forEach(function(panel) {
      var match = panel.getAttribute('data-viz-panel') === id;
      panel.classList.toggle('hidden', !match);
      panel.classList.toggle('block', match);
    });
  }
</script>
