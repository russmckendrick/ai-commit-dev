---
import ProviderIcon from './icons/ProviderIcons';

const providers = [
  { name: 'OpenAI', desc: 'GPT-5.4 series' },
  { name: 'Azure OpenAI', desc: 'Enterprise deployments' },
  { name: 'Anthropic', desc: 'Claude models' },
  { name: 'Groq', desc: 'Ultra-fast inference' },
  { name: 'Ollama', desc: 'Local models' },
  { name: 'Claude Code', desc: 'CLI provider' },
  { name: 'Codex', desc: 'CLI provider' },
];
---

<section id="providers" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="scroll-reveal mx-auto max-w-2xl text-center">
      <p class="text-sm font-medium uppercase tracking-[0.14em] text-accent">Providers</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight text-text">
        Your AI, your choice
      </h2>
      <p class="mt-4 text-base text-text-secondary leading-relaxed">
        Works with 7 providers out of the box — plus any OpenAI-compatible endpoint.
      </p>
    </div>

    <div class="scroll-reveal-stagger mt-14 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      {providers.map((p) => (
        <div class="group flex items-center gap-3 rounded-xl border border-border bg-surface p-4 transition-all hover:border-border-strong hover:bg-surface-raised">
          <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10 text-accent ring-1 ring-inset ring-accent/20 shrink-0">
            <ProviderIcon provider={p.name} size={20} />
          </span>
          <div class="min-w-0">
            <div class="text-sm font-semibold text-text truncate">{p.name}</div>
            <div class="text-xs text-text-tertiary truncate">{p.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
