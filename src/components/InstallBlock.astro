---
const tabs = [
  { id: 'macos', label: 'macOS' },
  { id: 'linux', label: 'Linux' },
  { id: 'windows', label: 'Windows' },
  { id: 'source', label: 'From Source' },
];
---

<section id="install" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="scroll-reveal mx-auto max-w-2xl text-center">
      <p class="text-sm font-medium uppercase tracking-[0.14em] text-accent">Install</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight text-text">
        Get started in seconds
      </h2>
      <p class="mt-4 text-base text-text-secondary leading-relaxed">
        Install <code>aic</code>, run setup, and start committing smarter.
      </p>
    </div>

    <div class="mt-12 mx-auto max-w-3xl">
      <!-- Tab bar -->
      <div class="flex items-center justify-center">
        <div class="inline-flex items-center gap-1 rounded-xl border border-border bg-surface/60 p-1 backdrop-blur">
          {tabs.map((tab, i) => (
            <button
              class:list={[
                'install-tab whitespace-nowrap px-4 py-1.5 text-sm font-medium rounded-lg transition-colors',
                i === 0 ? 'install-tab-active' : 'text-text-secondary hover:text-text'
              ]}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              data-install-tab={tab.id}
              onclick={`switchInstallTab('${tab.id}')`}
            >
              {tab.label}
            </button>
          ))}
        </div>
      </div>

      <div class="mt-6 install-panels">
        <div class="install-panel block" data-install-panel="macos">
          <div class="term">
            <div class="term-head">
              <div class="term-dots"><span class="term-dot r"></span><span class="term-dot y"></span><span class="term-dot g"></span></div>
              <span class="term-title">Homebrew</span>
            </div>
            <div class="term-body">
              <div><span class="prompt">$</span><span class="command">brew install russmckendrick/tap/aicommit</span></div>
              <div>&nbsp;</div>
              <div><span class="prompt">$</span><span class="command">aic setup</span></div>
            </div>
          </div>
        </div>

        <div class="install-panel hidden" data-install-panel="linux">
          <div class="term">
            <div class="term-head">
              <div class="term-dots"><span class="term-dot r"></span><span class="term-dot y"></span><span class="term-dot g"></span></div>
              <span class="term-title">Linux (amd64/arm64)</span>
            </div>
            <div class="term-body">
              <div><span class="prompt">$</span><span class="command">ARCH=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/')</span></div>
              <div><span class="prompt">$</span><span class="command">curl -sL "https://github.com/russmckendrick/aicommit/releases/latest/download/aic-linux-$&#123;ARCH&#125;" -o aic</span></div>
              <div><span class="prompt">$</span><span class="command">chmod +x aic && sudo mv aic /usr/local/bin/</span></div>
              <div>&nbsp;</div>
              <div><span class="prompt">$</span><span class="command">aic setup</span></div>
            </div>
          </div>
        </div>

        <div class="install-panel hidden" data-install-panel="windows">
          <div class="term">
            <div class="term-head">
              <div class="term-dots"><span class="term-dot r"></span><span class="term-dot y"></span><span class="term-dot g"></span></div>
              <span class="term-title">PowerShell</span>
            </div>
            <div class="term-body">
              <div><span class="prompt">PS&gt;</span><span class="command">Invoke-WebRequest -Uri "https://github.com/russmckendrick/aicommit/releases/latest/download/aic-windows-amd64.exe" -OutFile "aic.exe"</span></div>
              <div>&nbsp;</div>
              <div><span class="prompt">PS&gt;</span><span class="command">.\aic.exe setup</span></div>
            </div>
          </div>
        </div>

        <div class="install-panel hidden" data-install-panel="source">
          <div class="term">
            <div class="term-head">
              <div class="term-dots"><span class="term-dot r"></span><span class="term-dot y"></span><span class="term-dot g"></span></div>
              <span class="term-title">Cargo</span>
            </div>
            <div class="term-body">
              <div><span class="prompt">$</span><span class="command">git clone https://github.com/russmckendrick/aicommit.git</span></div>
              <div><span class="prompt">$</span><span class="command">cd aicommit</span></div>
              <div><span class="prompt">$</span><span class="command">cargo install --path .</span></div>
              <div>&nbsp;</div>
              <div><span class="prompt">$</span><span class="command">aic setup</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<script is:inline>
  function switchInstallTab(id) {
    document.querySelectorAll('[data-install-tab]').forEach(function(tab) {
      var isActive = tab.getAttribute('data-install-tab') === id;
      tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
      if (isActive) {
        tab.classList.add('install-tab-active');
        tab.classList.remove('text-text-secondary', 'hover:text-text');
      } else {
        tab.classList.remove('install-tab-active');
        tab.classList.add('text-text-secondary', 'hover:text-text');
      }
    });
    document.querySelectorAll('[data-install-panel]').forEach(function(panel) {
      var match = panel.getAttribute('data-install-panel') === id;
      panel.classList.toggle('hidden', !match);
      panel.classList.toggle('block', match);
    });
  }
</script>
