---
import TerminalAnimated from './TerminalAnimated';
import { heroDemo } from '../data/terminals/hero-demo';

const items: Array<[string, string]> = [
  ['Scope hints',    'Detected from staged paths — src/auth/ → auth.'],
  ['Branch context', 'Ticket IDs (PROJ-123, #456) picked up automatically.'],
  ['Chunk-safe',     'Large diffs are split, summarized, then synthesized.'],
  ['Push prompt',    'Single-remote default is Yes. Multi-remote is explicit.'],
];
---

<section class="section-elev">
  <div class="shell">
    <div class="hero-grid">
      <div>
        <div class="section-kicker">Live replay</div>
        <h2 class="section-title">Stage. Run. Ship.</h2>
        <p class="section-sub">
          A single invocation walks you from staged diff to pushed branch. When two or more files are staged, <span class="mono" style="color: var(--ink);">aic</span> can also split the change set into multiple AI-grouped commits.
        </p>
        <ul class="demo-list">
          {items.map(([k, v]) => (
            <li>
              <span class="key">{k}</span>
              <span>{v}</span>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <TerminalAnimated client:only="react" script={heroDemo} />
      </div>
    </div>
  </div>
</section>
