---
import { themes } from '../data/themes';
---

<div class="theme-showcase">
  {themes.map((theme) => (
    <button
      class="theme-card"
      data-theme-btn={theme.id}
      aria-label={`Switch to ${theme.name}`}
      aria-pressed="false"
      title={theme.name}
      style={`--card-bg: ${theme.background}; --card-surface: ${theme.surface}; --card-text: ${theme.primaryText}; --card-secondary: ${theme.secondaryText}; --card-accent: ${theme.accent}; --card-border: ${theme.border};`}
    >
      <div class="theme-card-preview">
        <div class="theme-card-chrome">
          <span style="background: #ff5f57;"></span>
          <span style="background: #febc2e;"></span>
          <span style="background: #28c840;"></span>
        </div>
        <div class="theme-card-body">
          <span class="line l1"></span>
          <span class="line l2"></span>
          <span class="line l3"></span>
          <span class="line l4"></span>
        </div>
      </div>
      <div class="theme-card-meta">
        <span class="theme-card-name">{theme.name}</span>
        <span class="theme-card-variant">{theme.variant}</span>
      </div>
    </button>
  ))}
</div>

<script is:inline>
  (function() {
    document.querySelectorAll('.theme-card[data-theme-btn]').forEach(function(card) {
      card.addEventListener('click', function() {
        var id = card.getAttribute('data-theme-btn');
        if (id && typeof window.__setTheme === 'function') {
          window.__setTheme(id);
        }
      });
    });
  })();
</script>
