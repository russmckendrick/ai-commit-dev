---
import TerminalAnimated from './TerminalAnimated';
import InstallCopy from './InstallCopy.astro';
import Icon from './Icon.astro';
import { flowCommit } from '../data/terminals/flow-commit';
import { heroInstall } from '../data/terminals/hero-install';
import { getLatestRelease } from '../lib/releases';

const latest = await getLatestRelease();
---

<section class="hero">
  <div class="shell">
    <div class="hero-grid">
      <div>
        <div class="hero-kickers">
          <div class="hero-kicker">
            <span class="dot"></span>
            <span>rust · MIT</span>
          </div>
          {latest && (
            <a class="hero-release" href="/releases" aria-label={`Latest release ${latest.tag}`}>
              <Icon name="tag" size={11} />
              <span>Latest {latest.tag}</span>
              <Icon name="arrow-up-right" size={10} />
            </a>
          )}
        </div>
        <h1>
          AI-generated commits, reviews &amp; PRs. <span class="mono">From the terminal.</span>
        </h1>
        <p class="lead">
          <span class="mono" style="color: var(--ink);">aic</span> is a single Rust binary that turns your staged diff into a conventional commit, drafts PR descriptions, reviews for bugs, and rewrites messy history — using the AI provider you already pay for.
        </p>
        <div class="hero-cta">
          <InstallCopy command={heroInstall.content} id="hero" />
          <a class="btn btn-ghost" href="#features">Features →</a>
        </div>
        <div class="hero-flags">
          <span>✓ macOS · Linux · Windows</span>
          <span>✓ 7 providers</span>
          <span>✓ Zero telemetry</span>
        </div>
      </div>
      <div>
        <TerminalAnimated client:only="react" script={flowCommit} />
      </div>
    </div>
  </div>
</section>
