---
---

<div class="mx-auto max-w-3xl">
  <div class="term">
    <div class="term-head">
      <div class="term-dots">
        <span class="term-dot r"></span>
        <span class="term-dot y"></span>
        <span class="term-dot g"></span>
      </div>
      <span class="term-title">aic workflow</span>
    </div>
    <div class="term-body">
      <div style="--delay: 0s" class="demo-line">
        <span class="prompt">$</span><span class="command">git add src/auth.rs</span>
      </div>
      <div style="--delay: 0.5s" class="demo-line">
        <span class="prompt">$</span><span class="command">aic</span>
      </div>
      <div style="--delay: 1s" class="demo-line">
        <span class="success">✓</span> <span class="output">Staged 1 file (src/auth.rs)</span>
      </div>
      <div style="--delay: 1.4s" class="demo-line">
        <span class="success">✓</span> <span class="output">Generating commit message…</span>
      </div>
      <div style="--delay: 2s" class="demo-line opacity-0">&nbsp;</div>
      <div style="--delay: 2.2s" class="demo-line text-base">
        <span class="highlight">feat(auth): add OAuth2 token refresh handler</span>
      </div>
      <div style="--delay: 2.6s" class="demo-line opacity-0">&nbsp;</div>
      <div style="--delay: 2.8s" class="demo-line">
        <span class="output">Accept? (Y/n/r/e)</span> <span class="command">y</span>
      </div>
      <div style="--delay: 3.3s" class="demo-line">
        <span class="success">✓</span> <span class="output">Committed:</span> <span class="highlight">feat(auth): add OAuth2 token refresh handler</span>
      </div>
    </div>
  </div>
</div>

<style>
  .demo-line {
    opacity: 0;
    animation: demoLineIn 0.45s ease forwards;
    animation-delay: var(--delay);
  }

  @keyframes demoLineIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
