---
import { getLatestRelease } from '../lib/releases';

const latest = await getLatestRelease();
const versionLabel = latest?.tag ?? 'v0.0.0';
---

<footer class="site-footer">
  <div class="shell">
    <div class="foot-grid">
      <div class="foot-col">
        <a href="/" class="brand" style="margin-bottom: 16px; display: inline-flex;">
          <span class="brand-mark">aic<span class="brand-caret"></span></span>
          <span class="brand-full">/ aicommit</span>
        </a>
        <p>A Rust CLI for AI-generated commits, reviews, and PR drafts. MIT licensed.</p>
      </div>
      <div class="foot-col">
        <h4>Docs</h4>
        <ul>
          <li><a href="/docs/installation">Installation</a></li>
          <li><a href="/docs/usage">Usage</a></li>
          <li><a href="/docs/configuration">Configuration</a></li>
          <li><a href="/docs/providers">Providers</a></li>
        </ul>
      </div>
      <div class="foot-col">
        <h4>Commands</h4>
        <ul>
          <li><a href="/docs/usage">aic</a></li>
          <li><a href="/docs/usage">aic review</a></li>
          <li><a href="/docs/usage">aic pr</a></li>
          <li><a href="/docs/map">aic map</a></li>
        </ul>
      </div>
      <div class="foot-col">
        <h4>Project</h4>
        <ul>
          <li><a href="https://github.com/russmckendrick/aicommit" target="_blank" rel="noopener noreferrer">GitHub</a></li>
          <li><a href="/releases">Releases</a></li>
          <li><a href="/docs/architecture">Architecture</a></li>
          <li><a href="https://github.com/russmckendrick/aicommit/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">License</a></li>
        </ul>
      </div>
    </div>
    <div class="foot-legal">
      <span>ai-commit.dev · <a href="/releases" class="foot-version">{versionLabel}</a></span>
      <span>Built with Rust</span>
    </div>
  </div>
</footer>
