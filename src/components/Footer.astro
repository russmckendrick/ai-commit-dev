---
---

<footer class="relative mt-24 border-t border-border">
  <div class="mx-auto max-w-7xl px-6 lg:px-8 py-12">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <div class="flex flex-col gap-3 max-w-sm">
        <div class="flex items-center gap-2">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-accent/10 ring-1 ring-accent/30">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-accent">
              <circle cx="12" cy="12" r="3"/>
              <line x1="3" y1="12" x2="9" y2="12"/>
              <line x1="15" y1="12" x2="21" y2="12"/>
            </svg>
          </span>
          <span class="font-semibold tracking-tight text-text">aic</span>
        </div>
        <p class="text-sm text-text-secondary leading-relaxed">
          A fast, opinionated CLI that lives in your terminal. Written in Rust, MIT licensed.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-8">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-text-tertiary">Product</p>
          <ul class="mt-3 flex flex-col gap-2">
            <li><a href="/#features" class="text-sm text-text-secondary hover:text-text transition-colors">Features</a></li>
            <li><a href="/#visualizations" class="text-sm text-text-secondary hover:text-text transition-colors">Visualizations</a></li>
            <li><a href="/#install" class="text-sm text-text-secondary hover:text-text transition-colors">Install</a></li>
          </ul>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-text-tertiary">Resources</p>
          <ul class="mt-3 flex flex-col gap-2">
            <li><a href="/docs" class="text-sm text-text-secondary hover:text-text transition-colors">Docs</a></li>
            <li><a href="https://github.com/russmckendrick/aicommit" target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-text transition-colors">GitHub</a></li>
            <li><a href="https://github.com/russmckendrick/aicommit/releases" target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-text transition-colors">Releases</a></li>
          </ul>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-text-tertiary">Built with</p>
          <ul class="mt-3 flex flex-col gap-2">
            <li><a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-text transition-colors">Astro</a></li>
            <li><a href="https://pages.cloudflare.com" target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-text transition-colors">Cloudflare Pages</a></li>
            <li><a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-text transition-colors">Tailwind CSS</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <p class="text-xs text-text-tertiary">
        © 2026 Russ McKendrick · MIT License
      </p>
      <p class="text-xs text-text-tertiary">
        Made with care for terminal lovers.
      </p>
    </div>
  </div>
</footer>
